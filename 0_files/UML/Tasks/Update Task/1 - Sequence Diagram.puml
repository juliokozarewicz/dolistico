@startuml Sequence_PUT_Task_By_Id
!theme plain
skinparam pageMargin 10
skinparam dpi 120
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderThickness 1.5
skinparam maxMessageSize 120
skinparam defaultFontSize 11

title PUT /api/v1/tasks/{id} — Sequence Diagram

actor       "Client"               as CLIENT
participant "Nginx\n(API Gateway)" as NGINX
participant "AuthFilter\n(JWT)"    as FILTER
participant "TasksUpdateController" as CTRL
participant "TasksUpdateUseCase"   as UC
participant "TasksEntity"          as ENTITY
participant "TasksRepository\n(interface)" as REPO
participant "TasksRepositoryImpl"  as IMPL
participant "TasksEventProducer"   as PRODUCER
participant "Kafka\ntasks.update.persist.v1" as KAFKA
participant "TasksEventConsumer"   as CONSUMER
participant "TasksRepositoryJPA"   as JPA
database    "PostgreSQL"           as DB

CLIENT -> NGINX  : PUT /api/v1/tasks/{id}\n+ JWT header + JSON body

NGINX  -> FILTER : forward request + JWT

alt JWT missing or invalid
    FILTER --> NGINX  : 401 INVALID_CREDENTIALS
    NGINX  --> CLIENT : 401 INVALID_CREDENTIALS
else JWT valid
    FILTER -> FILTER  : extract claims (userId, level)
    FILTER -> CTRL    : request + credentialsData attribute
end

CTRL -> CTRL : read credentialsData (userId)
CTRL -> CTRL : extract {id} from path variable
CTRL -> CTRL : validate UUID format

alt Invalid UUID format
    CTRL --> NGINX  : 400 BAD_REQUEST
    NGINX --> CLIENT : 400 BAD_REQUEST
else Valid UUID
    CTRL -> CTRL : @Valid TasksUpdateDTO (BindingResult)
    alt DTO validation failed
        CTRL --> NGINX  : 422 UNPROCESSABLE_ENTITY + fieldErrors
        NGINX --> CLIENT : 422 error
    else DTO valid
        CTRL -> UC : execute(credentialsData, taskId, dto)
    end
end

UC -> UC : parse userId from credentials
UC -> REPO : findByIdAndUser(taskId, userId)
REPO -> IMPL : findByIdAndUser(taskId, userId)
IMPL -> JPA  : findByIdAndIdUser(taskId, userId)
JPA  -> DB   : SELECT * FROM tasks.tasks\nWHERE id = ?\nAND id_user = ?
DB  --> JPA  : TasksModel or empty

alt Task not found
    JPA  --> IMPL : Optional.empty()
    IMPL --> REPO : Optional.empty()
    REPO --> UC   : Optional.empty()
    UC   --> CTRL : throws DomainException\nTASKS_NOT_FOUND
    CTRL --> NGINX : 404 TASKS_NOT_FOUND
    NGINX --> CLIENT : 404 TASKS_NOT_FOUND
else Task found
    JPA  --> IMPL : Optional<TasksModel>
    IMPL -> IMPL  : map TasksModel → TasksEntity
    IMPL --> REPO : Optional<TasksEntity>
    REPO --> UC   : Optional<TasksEntity>
end

UC -> UC : check duplicate:\nexistsByTaskNameAndDueDateAndIdNot\n(taskName, dueDate, taskId)
UC -> REPO : existsByTaskNameAndDueDateAndIdNot(...)
REPO -> IMPL : existsByTaskNameAndDueDateAndIdNot(...)
IMPL -> JPA  : existsByTaskNameAndDueDateAndIdNot(...)
JPA  -> DB   : SELECT EXISTS(\nWHERE task_name = ?\nAND due_date = ?\nAND id != ?)
DB  --> JPA  : true / false

alt Duplicated task name + dueDate
    JPA  --> IMPL : true
    IMPL --> REPO : true
    REPO --> UC   : true
    UC   --> CTRL : throws DomainException\nTASKS_DUPLICATED_TASK
    CTRL --> NGINX : 409 TASKS_DUPLICATED_TASK
    NGINX --> CLIENT : 409 TASKS_DUPLICATED_TASK
else Not duplicated
    UC -> UC : generate new timeStamp (now)
    UC -> ENTITY : new TasksEntity(\n  userId, taskId,\n  original.createdAt,\n  timeStamp (updated),\n  ...fields from command)
    ENTITY -> ENTITY : validateBusinessRules(\n  idUser, priority,\n  startTime, endTime,\n  allDay, reminderTime, dueDate)
end

alt Business rule violation
    ENTITY --> UC   : throws DomainException\n(TASKS_INVALID_PRIORITY /\nTASKS_INVALID_DATE_RANGE /\nTASKS_INVALID_ALLDAY /\nTASKS_INVALID_REMINDER)
    UC --> CTRL     : propagates exception
    CTRL --> NGINX  : 400 error
    NGINX --> CLIENT : 400 error
else Entity valid
    ENTITY --> UC   : TasksEntity (valid)
    UC -> PRODUCER  : producer(tasksEntity)
    PRODUCER -> PRODUCER : objectMapper\n.writeValueAsBytes(entity)
    PRODUCER -> KAFKA : send(\n  "tasks.update.persist.v1",\n  byte[] payload)\n.get(10s timeout)
end

alt Kafka send timeout / error
    KAFKA --> PRODUCER : exception
    PRODUCER --> UC    : throws InternalError
    UC --> CTRL        : propagates
    CTRL --> NGINX     : 503 SERVICE_UNAVAILABLE
    NGINX --> CLIENT   : 503 error
else Kafka received
    KAFKA --> PRODUCER : ack
    PRODUCER --> UC    : returns
    UC --> CTRL        : taskId (String)

    CTRL -> CTRL : build dataObject {idUpdated}
    CTRL -> CTRL : build links\n{self: PUT /tasks/{id},\ncollection: GET /tasks,\ndetail: GET /tasks/{id}}
    CTRL -> CTRL : build StandardResponseDTO\n(200, TASKS_UPDATED_SUCCESSFULLY)
    CTRL --> NGINX  : 200 OK + JSON body
    NGINX --> CLIENT : 200 OK + JSON body

    note over KAFKA, DB
        Async persistence flow
    end note

    KAFKA -> CONSUMER : poll record (byte[] payload)
    CONSUMER -> CONSUMER : objectMapper\n.readValue(payload, TasksEntity)
    CONSUMER -> REPO  : update(tasksEntity)
    REPO -> IMPL      : update(tasksEntity)
    IMPL -> IMPL      : lookup CategoryModel\nby tasksEntity.category (nullable)
    IMPL -> JPA       : findByIdAndIdUser\n(taskId, userId)
    JPA  -> DB        : SELECT * FROM tasks.tasks\nWHERE id = ?\nAND id_user = ?
    DB  --> JPA       : TasksModel
    IMPL -> IMPL      : update fields on TasksModel
    IMPL -> JPA       : save(updatedTasksModel)
    JPA  -> DB        : UPDATE tasks.tasks\nSET ... WHERE id = ?
    DB  --> JPA       : updated
    JPA --> IMPL      : ok
    IMPL --> REPO     : ok
    REPO --> CONSUMER : ok
    CONSUMER -> KAFKA : ack.acknowledge()
end

@enduml