@startuml Sequence_GET_Task_By_Id
!theme plain
skinparam pageMargin 10
skinparam dpi 120
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderThickness 1.5
skinparam maxMessageSize 120
skinparam defaultFontSize 11

title GET /api/v1/tasks/{id} — Sequence Diagram

actor       "Client"               as CLIENT
participant "Nginx\n(API Gateway)" as NGINX
participant "AuthFilter\n(JWT)"    as FILTER
participant "TasksGetByIdController" as CTRL
participant "TasksGetByIdUseCase"  as UC
participant "TasksRepository\n(interface)" as REPO
participant "TasksRepositoryImpl"  as IMPL
participant "TasksRepositoryJPA"   as JPA
database    "PostgreSQL"           as DB

CLIENT -> NGINX  : GET /api/v1/tasks/{id}\n+ JWT header

NGINX  -> FILTER : forward request + JWT

alt JWT missing or invalid
    FILTER --> NGINX  : 401 INVALID_CREDENTIALS
    NGINX  --> CLIENT : 401 INVALID_CREDENTIALS
else JWT valid
    FILTER -> FILTER  : extract claims (userId, level)
    FILTER -> CTRL    : request + credentialsData attribute
end

CTRL -> CTRL : read credentialsData (userId)
CTRL -> CTRL : extract {id} from path variable
CTRL -> CTRL : validate UUID format

alt Invalid UUID format
    CTRL --> NGINX  : 400 BAD_REQUEST
    NGINX --> CLIENT : 400 BAD_REQUEST
else Valid UUID
    CTRL -> UC : execute(credentialsData, taskId)
end

UC -> UC : parse userId from credentials
UC -> REPO : findByIdAndUser(taskId, userId)
REPO -> IMPL : findByIdAndUser(taskId, userId)
IMPL -> JPA  : findByIdAndIdUser(taskId, userId)
JPA  -> DB   : SELECT * FROM tasks.tasks\nWHERE id = ?\nAND id_user = ?
DB  --> JPA  : TasksModel or empty

alt Task not found or belongs to another user
    JPA  --> IMPL : Optional.empty()
    IMPL --> REPO : Optional.empty()
    REPO --> UC   : Optional.empty()
    UC   --> CTRL : throws DomainException\nTASKS_NOT_FOUND
    CTRL --> NGINX : 404 TASKS_NOT_FOUND
    NGINX --> CLIENT : 404 TASKS_NOT_FOUND
else Task found
    JPA  --> IMPL : Optional<TasksModel>
    IMPL -> IMPL  : map TasksModel → TasksEntity
    IMPL --> REPO : Optional<TasksEntity>
    REPO --> UC   : Optional<TasksEntity>
    UC   --> CTRL : TasksEntity
end

CTRL -> CTRL : map TasksEntity → response data object
CTRL -> CTRL : build links\n{self: GET /tasks/{id},\ncollection: GET /tasks}
CTRL -> CTRL : build StandardResponseDTO\n(200, GET_TASK_SUCCESS)
CTRL --> NGINX  : 200 OK + JSON body
NGINX --> CLIENT : 200 OK + JSON body

@enduml
