@startuml Activity_GET_Tasks
!theme plain
skinparam pageMargin 10
skinparam dpi 120
skinparam defaultFontSize 11
skinparam ActivityBorderThickness 1.5
skinparam ActivityArrowThickness 1.5
skinparam activityDiamondBorderThickness 1.5

title GET /api/v1/tasks — Activity Diagram

|Client|
start
:Send GET /api/v1/tasks\n+ JWT header\n+ optional query params\n(taskName, priority, category,\nlocation, dueDate, page, size);

|Nginx (API Gateway)|
:Receive request;
:Forward to Tasks Service;

|AuthFilter|
:Intercept request;
if (JWT present?) then (no)
    :Return 401\nINVALID_CREDENTIALS;
    |Client|
    :Receive 401 error;
    stop
else (yes)
    :Validate JWT signature\n& expiration;
    if (JWT valid?) then (no)
        :Return 401\nACCESS_EXPIRED;
        |Client|
        :Receive 401 error;
        stop
    else (yes)
        :Extract claims\n(userId, level);
        :Set credentialsData\nattribute on request;
    endif
endif

|TasksGetController|
:Receive request\n+ credentialsData;
:Parse query params\ninto TasksGetDTO;
:Validate DTO\n(@Valid + BindingResult);
if (DTO invalid?) then (yes)
    :Return 422\nUNPROCESSABLE_ENTITY\n+ fieldErrors;
    |Client|
    :Receive 422 error;
    stop
else (no)
    :Call TasksGetUseCase\n.execute(credentials, command);
endif

|TasksGetUseCase|
:Extract userId\nfrom credentialsData;
:Validate page size\n(max 100 items);
if (page size > 100?) then (yes)
    :Throw DomainException\nBAD_REQUEST;
    |TasksGetController|
    :Return 400 BAD_REQUEST;
    |Client|
    :Receive 400 error;
    stop
else (no)
    :Build filter criteria\nfrom command;
    :Call TasksRepository\n.findAllByUser(\n  userId, filters, pageable);
endif

|TasksRepositoryImpl|
:Receive userId +\nfilters + pageable;
:Build Specification\nchain (AND predicates):;
note right
  - belongsToUser(userId)  [always]
  - hasTaskName(name?)
  - hasPriority(priority?)
  - hasCategory(uuid?)
  - hasLocation(location?)
  - hasDueDate(dueDate?)
end note
:Call JPA.findAll(\nSpecification, Pageable);

|PostgreSQL|
:Execute SQL:\nSELECT ... FROM tasks.tasks\nWHERE id_user = ?\n[AND filters...]\nORDER BY created_at DESC\nLIMIT ? OFFSET ?;
if (DB error?) then (yes)
    :Throw exception;
    |TasksGetController|
    :Return 503\nSERVICE_UNAVAILABLE;
    |Client|
    :Receive 503 error;
    stop
else (no)
    :Return Page<TasksModel>\n+ total count;
endif

|TasksRepositoryImpl|
:Map each TasksModel\n→ TasksEntity;
:Return Page<TasksEntity>\n(content + metadata);

|TasksGetUseCase|
:Return Page<TasksEntity>\nto controller;

|TasksGetController|
:Build data list\nfrom page content;
:Build meta object:\n{page, size, totalElements,\ntotalPages};
:Build links:\n{self, next?, prev?};
:Build StandardResponseDTO\n(200, TASKS_RETRIEVED_SUCCESSFULLY,\ndata, meta, links);
:Return 200 OK + JSON;

|Nginx (API Gateway)|
:Forward 200 response;

|Client|
:Receive 200 OK\n+ paginated task list;
stop

@enduml